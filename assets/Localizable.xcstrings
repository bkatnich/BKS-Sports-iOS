      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You have an active subscription. Deleting your account will not automatically cancel it. Cancel your subscription in Apple ID settings first to avoid further charges."
