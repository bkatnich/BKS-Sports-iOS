    "profile.deleteAccount.subscriptionWarning.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You have an active subscription. Deleting your account will not automatically cancel it. Cancel your subscription in Apple ID settings first to avoid further charges."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tienes una suscripción activa. Eliminar tu cuenta no la cancelará automáticamente. Cancela tu suscripción en Configuración de Apple ID primero para evitar cargos adicionales."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous avez un abonnement actif. La suppression de votre compte ne l'annulera pas automatiquement. Annulez votre abonnement dans les réglages Apple ID d'abord pour éviter des frais supplémentaires."
          }
        }
      }
    },
